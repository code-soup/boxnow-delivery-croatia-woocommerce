{
    "name": "codesoup-boxnow-delivery",
    "version": "1.0.0",
    "license": "GPL-3.0",
    "keywords": [
        "wordpress",
        "woocommerce",
        "shipping",
        "boxnow",
        "croatia",
        "delivery",
        "locker"
    ],
    "description": "BOX NOW delivery service for WooCommerce in Croatia",
    "repository": {
        "type": "git",
        "url": "https://github.com/code-soup/box-now-delivery-for-woocommerce-croatia.git"
    },
    "bugs": {
        "url": "https://github.com/code-soup/box-now-delivery-for-woocommerce-croatia/issues"
    },
    "type": "module",
    "engines": {
        "node": ">=22.0.0"
    },
    "authors": [
        {
            "homepage": "https://www.codesoup.co",
            "name": "Code Soup",
            "email": "hi@codesoup.co"
        }
    ],
    "browserslist": [
        "> 0.5%",
        "last 2 versions",
        "not dead"
    ],
    "scripts": {
        "dev": "webpack serve --hot --mode development --color --config src/config/config.webpack.js",
        "build": "webpack --mode production --progress --config src/config/config.webpack.js",
        "build:prod": "webpack --mode production --progress --config src/config/config.webpack.js",
        "build:dev": "webpack --mode development --progress --config src/config/config.webpack.js",
        "analyze": "webpack --mode production --progress --config src/config/config.webpack.js --analyze",
        "analyze:dev": "webpack --mode development --progress --config src/config/config.webpack.js --analyze",
        "lint": "npm run -s lint:scripts && npm run -s lint:styles",
        "lint:scripts": "eslint src/scripts src/config",
        "lint:styles": "stylelint \"src/styles/**/*.{css,sass,scss}\"",
        "reinit": "rimraf dist && rimraf node_modules && npm install",
        "clean": "rimraf dist",
        "setup": "chmod u+x ./setup/setup.sh && ./setup/setup.sh",
        "lint:fix": "npm run lint:scripts -- --fix && npm run lint:styles -- --fix"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/plugin-transform-class-properties": "^8.0.1",
        "@babel/plugin-transform-private-methods": "^8.0.1",
        "@babel/preset-env": "^8.0.2",
        "@eslint/js": "^10.0.1",
        "babel-loader": "^10.1.1",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.7.0",
        "eslint-plugin-import-x": "^4.17.1",
        "eslint-webpack-plugin": "^6.0.0",
        "globals": "^17.7.0",
        "import-glob": "^1.5.0",
        "mini-css-extract-plugin": "^2.10.2",
        "postcss": "^8.5.19",
        "postcss-loader": "^8.2.1",
        "postcss-preset-env": "^11.3.2",
        "resolve-url-loader": "^5.0.0",
        "rimraf": "^6.1.3",
        "sass": "^1.101.0",
        "sass-loader": "^17.0.0",
        "style-loader": "^4.0.0",
        "stylelint": "^17.14.0",
        "stylelint-config-property-sort-order-smacss": "^11.2.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-webpack-plugin": "^5.1.0",
        "svg-spritemap-webpack-plugin": "^5.1.4",
        "terser-webpack-plugin": "^5.6.1",
        "webpack": "^5.108.4",
        "webpack-bundle-analyzer": "^5.3.0",
        "webpack-cli": "^7.2.1",
        "webpack-dev-server": "^6.0.0",
        "webpack-manifest-plugin": "^6.0.1",
        "webpack-merge": "^6.0.1"
    }
}
